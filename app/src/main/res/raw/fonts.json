    "ivritaSyntax": {
      "description": "Official Ivrita notation rules from alefalefalef.co.il/ivrita",
      "rules": [
        {
          "id": 1,
          "name": "סיומת ־ה",
          "pattern": "ו/ה or ו.ה",
          "examples": ["שלו/ה", "חרוץ.ה"],
          "male": "שלו, חרוץ",
          "female": "שלה, חרוצה"
        },
        {
          "id": 2,
          "name": "סיומת ־ות",
          "pattern": "י/ות or י.ות",
          "examples": ["עורכי/ות", "אנשי.ות"],
          "male": "עורכי, אנשי",
          "female": "עורכות, אנשות"
        },
        {
          "id": 3,
          "name": "סיומת ־י (ציווי/עתיד)",
          "pattern": "/י or .י or (י)",
          "examples": ["משוך.י", "ענה/י", "הפע(י)ל/י"],
          "male": "משוך, ענה, הפעל",
          "female": "משכי, עני, הפעילי"
        },
        {
          "id": 4,
          "name": "סיומת ־ית",
          "pattern": "/ית or .ית",
          "examples": ["סטודנט/ית", "מומחה.ית"],
          "male": "סטודנט, מומחה",
          "female": "סטודנטית, מומחית"
        },
        {
          "id": 5,
          "name": "סיומת ־ים/ות",
          "pattern": "ים/ות or ות.ים or יםות",
          "examples": ["דרושים/ות", "נערות.ים", "צעיריםות"],
          "male": "דרושים, נערים, צעירים",
          "female": "דרושות, נערות, צעירות"
        },
        {
          "id": 6,
          "name": "סיומת ־ים/יות",
          "pattern": "ים/יות or ות/ים",
          "examples": ["פרילנסרים/יות", "ישראליות/ים"],
          "male": "פרילנסרים, ישראלים",
          "female": "פרילנסריות, ישראליות"
        },
        {
          "id": 7,
          "name": "סיומת ־ם/ן (שייכות)",
          "pattern": "ם/ן or ן/ם or םן or נם",
          "examples": ["שלכם/ן", "ליבכן/ם", "בתיכםן", "ריחןם", "הערותיהם/ן"],
          "male": "שלכם, ליבכם, בתיכם, ריחם, הערותיהם",
          "female": "שלכן, ליבכן, בתיכן, ריחן, הערותיהן"
        },
        {
          "id": 8,
          "name": "סיומת ־נה (ציווי/עתיד רבים)",
          "pattern": "ו/נה",
          "examples": ["בקשו/נה", "תדרכו/נה", "י/תבדקו/נה", "רקדו/נה"],
          "male": "בקשו, תדרכו, יבדקו, רקדו",
          "female": "בקשנה, תדרכנה, תבדקנה, רקדנה"
        },
        {
          "id": 9,
          "name": "סיומת ־ת",
          "pattern": "/ת or .ת",
          "examples": ["מעצב/ת", "איש/ת"],
          "male": "מעצב, איש",
          "female": "מעצבת, אשת"
        },
        {
          "id": 10,
          "name": "סיומת ־תה (עבר גוף שלישי)",
          "pattern": "ה/תה",
          "examples": ["הלווה/תה", "בכה/תה"],
          "male": "הלווה, בכה",
          "female": "הלוותה, בכתה"
        },
        {
          "id": 11,
          "name": "סיומת ־תי",
          "pattern": "י/תי or /תי",
          "examples": ["יקירי/תי", "אהוב/תי", "אחי/ותי"],
          "male": "יקירי, אהובי, אחי",
          "female": "יקירתי, אהובתי, אחותי"
        },
        {
          "id": 12,
          "name": "י/ת־ בתחילת מילה",
          "pattern": "י/ת or ת/י at start",
          "examples": ["י/תכתוב", "ת/יבוא"],
          "male": "יכתוב, יבוא",
          "female": "תכתוב, תבוא"
        },
        {
          "id": 13,
          "name": "א.נשים",
          "pattern": "א.נשים or א/נשים or א־נשים",
          "examples": ["א.נשים", "א/נשי", "א/נשות"],
          "male": "אנשים, אנשי, אנשי",
          "female": "נשים, נשות, נשות"
        },
        {
          "id": 14,
          "name": "סוגריים (✱)",
          "pattern": "(letter) - optional letter for female",
          "examples": ["סב(ת)א", "חבר(ת)ו", "עלי(י)ך", "פנ(י)יך", "חושב(ת)"],
          "male": "סבא, חברו, עליך, פניך, חושב",
          "female": "סבתא, חברתו, עלייך, פנייך, חושבת"
        },
        {
          "id": 15,
          "name": "מילים שלמות",
          "pattern": "word/word",
          "examples": ["בן/בת", "היא/הוא", "איש/אשת", "אחת/אחד"],
          "male": "בן, הוא, איש, אחד",
          "female": "בת, היא, אשת, אחת"
        },
        {
          "id": 16,
          "name": "פיצול כפול (יחיד/יחידה/רבים)",
          "pattern": "x.y.z or x/y/z",
          "examples": ["שמור.י.ו", "שלח/י/ו"],
          "male": "שמור, שלח",
          "female": "שמרי, שלחי",
          "plural": "שמרו, שלחו"
        },
        {
          "id": 17,
          "name": "[] סוגריים מרובעים",
          "pattern": "[male|female|neutral]",
          "examples": ["[גבר|אישה|אדם]", "[בן|בת]", "[מהממת|חתיך|יפה]", "סב[ים|תות]"],
          "male": "גבר, בן, חתיך, סבים",
          "female": "אישה, בת, מהממת, סבתות",
          "neutral": "אדם, בן/בת, יפה"
        },
        {
          "id": 18,
          "name": "{} סוגריים מסולסלים",
          "pattern": "{word} - skip processing",
          "examples": ["{שלכם/ן}", "{גולשים/ות}"],
          "result": "שלכם/ן, גולשים/ות (unchanged)"
        },
        {
          "id": 19,
          "name": "data-ivrita HTML attributes",
          "pattern": "data-ivrita-male/female/neutral",
          "example": "<strong data-ivrita-male=\"חתיך\" data-ivrita-female=\"מהממת\" data-ivrita-neutral=\"\">יפה</strong>",
          "note": "Advanced HTML-based gender alternatives"
        }
      ]
    },
    "mghebrewGlyphs": {
      "description": "PUA glyphs in MGHebrew fonts - hybrid characters combining male/female endings",
      "note": "These are font glyphs, separate from Ivrita JS text processing",
      "glyphs": [
        {
          "id": 1,
          "name": "יו״ב",
          "nameEn": "yuv",
          "pua": "U+E000",
          "char": "\uE000",
          "male": "וא",
          "female": "יא",
          "pattern": "הוא/היא",
          "example": "הוא/יא"
        },
        {
          "id": 2,
          "name": "תי״ם",
          "nameEn": "tem",
          "pua": "U+E001",
          "char": "\uE001",
          "male": "ים",
          "female": "ות",
