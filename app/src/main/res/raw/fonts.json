          "example": "מורים/ות"
        },
        {
          "id": 3,
          "name": "נ״ם",
          "nameEn": "nem",
          "pua": "U+E002",
          "char": "\uE002",
          "male": "ם",
          "female": "ן",
          "pattern": "2nd person plural suffix",
          "example": "אתם/ן"
        },
        {
          "id": 4,
          "name": "ת״ד",
          "nameEn": "tad",
          "pua": "U+E003",
          "char": "\uE003",
          "male": "ד",
          "female": "ת",
          "pattern": "present tense verbs",
          "example": "עומד/ת"
        },
        {
          "id": 5,
          "name": "נ״ת",
          "nameEn": "nat",
          "pua": "U+E004",
          "char": "\uE004",
          "male": "נ",
          "female": "ת",
          "pattern": "adjectives ending נ",
          "example": "ישנ/ת"
        },
        {
          "id": 6,
          "name": "י״ת",
          "nameEn": "yat",
          "pua": "U+E005",
          "char": "\uE005",
          "male": "י",
          "female": "ת",
          "pattern": "nationality adjectives",
          "example": "עברי/ת"
        },
        {
          "id": 7,
          "name": "ה״ת",
          "nameEn": "hat",
          "pua": "U+E006",
          "char": "\uE006",
          "male": "ה",
          "female": "ת",
          "pattern": "adjectives ending ה",
          "example": "יפה/ת"
        },
        {
          "id": 8,
          "name": "ו״ה",
          "nameEn": "vah",
          "pua": "U+E007",
          "char": "\uE007",
          "male": "ו",
          "female": "ה",
          "pattern": "possessive pronouns",
          "example": "שלו/ה"
        },
        {
          "id": 9,
          "name": "א״ן",
          "nameEn": "an",
          "pua": "U+E008",
          "char": "\uE008",
          "male": "א",
          "female": "",
          "pattern": "optional alef",
          "example": "הוא."
        },
        {
          "id": 10,
          "name": "ת״ה",
          "nameEn": "tah",
          "pua": "U+E009",
          "char": "\uE009",
          "male": "",
          "female": "ת",
          "pattern": "optional tav",
          "example": "רופא/ת"
        },
        {
          "id": 11,
          "name": "ני״ת",
          "nameEn": "nit",
          "pua": "U+E00A",
          "char": "\uE00A",
          "male": "ן",
          "female": "נית",
          "pattern": "professional nouns",
          "example": "זמרן/ית"
        },
        {
          "id": 12,
          "name": "רֵב",
          "nameEn": "rev",
          "pua": "U+E00B",
          "char": "\uE00B",
          "male": "-",
          "female": "-",
          "pattern": "nikud reversal",
          "example": "מוֹר[ֶה|ָה]",
          "note": "Swaps vowels in nikud text"
        }
      ]
    },
